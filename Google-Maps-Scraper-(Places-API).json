      "parameters": {
        "jsCode": "\nconst baseUrl = $input.first().json.URL.replace(/\\/$/, \"\");\n\nreturn [\n  { json: { url: baseUrl } },\n  { json: { url: `${baseUrl}/kontakt/` } },\n  { json: { url: `${baseUrl}/impressum/` } },\n  { json: { url: `${baseUrl}/team/` } }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2560,
        592
      ],
      "id": "18e910fb-cad2-4de4-9b27-9d19ce414a43",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "// 1. Hole Ergebnisse aller 4 Seiten\nconst items = $input.all();\n\n// 2. Text zusammenbauen\nlet fullText = \"\";\n\nfor (const item of items) {\n  // Text aus dem HTML-Node holen\n  let content = item.json.cleaned_text || \"\";\n  const url = item.json.url || \"Webseite\";\n\n  // --- NEU: URL-Bereinigung ---\n  \n  // 1. Entfernt alles, was mit http:// oder https:// beginnt (bis zum nächsten Leerzeichen)\n  content = content.replace(/https?:\\/\\/[^\\s]+/g, '');\n  \n  // 2. Entfernt alles, was mit www. beginnt\n  content = content.replace(/www\\.[^\\s]+/g, '');\n\n  // 3. Entfernt E-Mail-Adressen (Optional, falls du nur Kontaktformular willst)\n  // content = content.replace(/[\\w\\.-]+@[\\w\\.-]+\\.\\w+/g, ''); \n\n  // 4. Aufräumen: Doppelte Leerzeichen entfernen, die durch das Löschen entstanden sind\n  content = content.replace(/\\s+/g, ' ').trim();\n\n  // -----------------------------\n\n  // Nur hinzufügen, wenn nach der Reinigung noch Text da ist\n  if (content.length > 20) { // Habe Limit auf 20 erhöht, um leere Fragmente zu filtern\n    fullText += `\\n\\n========================================\\n`;\n    fullText += `QUELLE: ${url}\\n`;\n    fullText += `========================================\\n`;\n    fullText += content + \"\\n\";\n  }\n}\n\n// 3. Ergebnis zurückgeben\nreturn {\n  json: {\n    combined_text: fullText\n  }\n};"
      },
