    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"firmen_profil\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"firmen_name_rechtlich\": {\n          \"type\": [\"string\", \"null\"],\n          \"description\": \"Offizieller Name inkl. Rechtsform aus Impressum. Null wenn nicht gefunden.\"\n        },\n        \"branche_kurz\": {\n          \"type\": \"string\",\n          \"description\": \"Kurze Einordnung: z.B. 'Fahrschule', 'SHK-Betrieb', 'Zahnarzt'\"\n        }\n      }\n    },\n    \"sales_analyse_fuer_ki_bot\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"nutzen_argumentation\": {\n          \"type\": \"string\",\n          \"description\": \"Eine prägnante Erklärung zum Pain Point. Z.B.: 'Da Sie Mittags geschlossen haben, entgehen Ihnen Anrufe.'\"\n        },\n        \"terminbuchung_modus\": {\n          \"type\": \"string\",\n          \"description\": \"Wie bucht man aktuell? (Telefon, Email, Tool)\"\n        },\n        \"oeffnungszeiten_analyse\": {\n          \"type\": \"string\",\n          \"description\": \"Kritische Analyse der Erreichbarkeit.\"\n        }\n      }\n    },\n    \"ansprechpartner\": {\n      \"type\": \"array\",\n      \"description\": \"Liste echter Personen. KEINE Platzhalter.\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"full_name\": {\n            \"type\": \"string\",\n            \"description\": \"Voller Name der Person (GF, Inhaber). KEINE Fiktiven Namen.\"\n          },\n          \"rolle\": {\n            \"type\": \"string\",\n            \"description\": \"Position im Unternehmen (z.B. Geschäftsführer, Inhaber)\"\n          },\n          \"email_persoenlich\": {\n            \"type\": [\"string\", \"null\"],\n            \"description\": \"STRIKT: Nur echte, gefundene persönliche E-Mails (z.B. m.mueller@firma.de). KEINE 'info@', KEINE konstruierten E-Mails. Wenn nicht im Text gefunden, MUSS dies der JSON-Wert null sein (NICHT der String 'null').\"\n          }\n        }\n      }\n    },\n    \"kontakt_zentrale\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"telefon_zentrale\": {\n          \"type\": [\"string\", \"null\"],\n          \"description\": \"Allgemeine Rufnummer.\"\n        },\n        \"email_allgemein\": {\n          \"type\": [\"string\", \"null\"],\n          \"description\": \"Allgemeine E-Mail wie info@, kontakt@, buero@.\"\n        }\n      }\n    }\n  },\n  \"required\": [\n    \"firmen_profil\",\n    \"sales_analyse_fuer_ki_bot\",\n    \"ansprechpartner\",\n    \"kontakt_zentrale\"\n  ]\n}",
        "autoFix": "={{ false }}"
      },
