    {
      "parameters": {
        "jsCode": "// Dieser Code repariert KI-Fehler (Strings wie \"null\", \"NULL\", \"n/a\" werden zu echtem null)\n\nreturn $input.all().map(item => {\n  // Wir arbeiten auf einer Kopie der JSON-Daten\n  let data = item.json;\n\n  // Rekursive Funktion, die durch alle Ebenen des Objekts geht\n  const cleanData = (obj) => {\n    // Wenn das Objekt null ist, hör auf\n    if (!obj) return;\n\n    for (const key in obj) {\n      const value = obj[key];\n\n      // 1. Fall: Es ist ein String -> Prüfen ob es \"null\" oder \"n/a\" ist\n      if (typeof value === 'string') {\n        const lower = value.trim().toLowerCase();\n        // Liste der \"bösen Wörter\", die die KI gerne statt leerem Feld nutzt\n        if (['null', 'n/a', 'none', 'keine angabe', 'not found', 'undefined'].includes(lower)) {\n          obj[key] = null; // Ersetze Text durch echtes NULL\n        }\n      }\n      \n      // 2. Fall: Es ist ein Array (z.B. ansprechpartner) -> Durchlaufe jedes Item\n      else if (Array.isArray(value)) {\n        value.forEach(subItem => cleanData(subItem));\n      }\n      \n      // 3. Fall: Es ist ein verschachteltes Objekt (z.B. firmen_profil) -> Geh tiefer rein\n      else if (typeof value === 'object' && value !== null) {\n        cleanData(value);\n      }\n    }\n  };\n\n  // Starte den Reinigungsprozess\n  cleanData(data);\n\n  return item;\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3776,
        592
      ],
      "id": "11b49cda-76da-401c-afc5-19347da9eb5b",
      "name": "Code in JavaScript3"
